/**
 * 星露谷物语 - 社交页面样式
 */

.social-container {
  width: 100%;
  min-height: 100vh;
  background: #2c3e50;
}

.header {
  padding: 30rpx;
  background: rgba(0, 0, 0, 0.3);
  border-bottom: 3rpx solid #f39c12;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #f39c12;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: #bdc3c7;
  margin-top: 5rpx;
}

.villager-list {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
}

.villager-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 15rpx;
  background: rgba(52, 73, 94, 0.8);
  border-radius: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.villager-item:active {
  background: rgba(52, 152, 219, 0.3);
}

.villager-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(52, 152, 219, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  border: 3rpx solid #3498db;
}

.avatar-icon {
  font-size: 40rpx;
}

.villager-info {
  flex: 1;
}

.villager-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #ecf0f1;
  margin-bottom: 6rpx;
}

.villager-location {
  display: block;
  font-size: 22rpx;
  color: #95a5a6;
  margin-bottom: 10rpx;
}

.hearts-bar {
  display: flex;
  align-items: center;
  gap: 3rpx;
}

.heart {
  font-size: 20rpx;
}

.heart.filled {
  color: #e74c3c;
}

.heart.empty {
  color: #7f8c8d;
}

.hearts-text {
  font-size: 18rpx;
  color: #bdc3c7;
  margin-left: 10rpx;
}

.villager-status {
  display: flex;
  gap: 8rpx;
}

.status-icon {
  font-size: 24rpx;
}

/* 详情面板 */
.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-panel {
  width: 85%;
  max-width: 600rpx;
  background: #34495e;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 3rpx solid #f39c12;
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
}

.detail-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(52, 152, 219, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  border: 4rpx solid #3498db;
}

.detail-icon {
  font-size: 50rpx;
}

.detail-info {
  flex: 1;
}

.detail-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #f39c12;
  margin-bottom: 8rpx;
}

.detail-location {
  display: block;
  font-size: 24rpx;
  color: #bdc3c7;
  margin-bottom: 12rpx;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  background: #e74c3c;
  color: white;
  border: none;
  border-radius: 50%;
  font-size: 32rpx;
  padding: 0;
  line-height: 56rpx;
}

.close-btn::after { border: none; }

.detail-actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx;
  border-radius: 10rpx;
  border: none;
  font-size: 22rpx;
}

.action-btn::after { border: none; }

.talk-btn {
  background: #3498db;
  color: white;
}

.gift-btn {
  background: #27ae60;
  color: white;
}

.info-btn {
  background: #f39c12;
  color: white;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

/* 对话框 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-panel {
  width: 80%;
  max-width: 500rpx;
  background: #34495e;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 3rpx solid #3498db;
  text-align: center;
}

.dialog-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #f39c12;
  margin-bottom: 20rpx;
}

.dialog-text {
  display: block;
  font-size: 26rpx;
  color: #ecf0f1;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.dialog-close {
  background: #3498db;
  color: white;
  border: none;
  padding: 12rpx 40rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.dialog-close::after { border: none; }

/* 送礼面板 */
.gift-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1050;
  display: flex;
  align-items: flex-end;
}

.gift-panel {
  width: 100%;
  max-height: 60vh;
  background: #34495e;
  border-radius: 20rpx 20rpx 0 0;
  padding: 25rpx;
  border-top: 3rpx solid #f39c12;
}

.gift-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.gift-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #f39c12;
}

.gift-list {
  max-height: 50vh;
}

.gift-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
}

.gift-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx;
  background: rgba(44, 62, 80, 0.8);
  border-radius: 10rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.gift-item:active {
  background: rgba(52, 152, 219, 0.3);
}

.gift-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.gift-name {
  font-size: 20rpx;
  color: #ecf0f1;
}