/**
 * 星露谷物语 - 游戏页面样式
 */

.game-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.status-bar {
  display: flex;
  justify-content: space-around;
  padding: 12rpx;
  background: #2c3e50;
  color: #ecf0f1;
  font-size: 22rpx;
}

.status-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.game-canvas {
  flex: 1;
  width: 100%;
  background: #90EE90;
}

.seed-selector {
  position: absolute;
  bottom: 130rpx;
  left: 0;
  width: 100%;
  background: #34495e;
  padding: 15rpx;
  transform: translateY(100%);
  transition: transform 0.3s;
  z-index: 100;
}

.seed-selector.show {
  transform: translateY(0);
}

.seed-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #ecf0f1;
  margin-bottom: 15rpx;
}

.close-btn {
  width: 40rpx;
  height: 40rpx;
  background: #e74c3c;
  color: white;
  border: none;
  border-radius: 50%;
  font-size: 24rpx;
  padding: 0;
  line-height: 40rpx;
}

.close-btn::after { border: none; }

.seed-list {
  white-space: nowrap;
}

.seed-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx;
  margin-right: 15rpx;
  background: #2c3e50;
  border-radius: 10rpx;
  border: 2rpx solid #7f8c8d;
}

.seed-item.selected {
  border-color: #f39c12;
  background: #34495e;
}

.seed-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.seed-name {
  font-size: 20rpx;
  color: #ecf0f1;
  margin-bottom: 4rpx;
}

.seed-cost {
  font-size: 18rpx;
  color: #f39c12;
}

.toolbar {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 12rpx;
  background: #34495e;
  border-top: 3rpx solid #2c3e50;
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 14rpx;
  background: #e74c3c;
  color: white;
  border-radius: 8rpx;
  font-size: 18rpx;
  border: none;
  transition: all 0.2s;
}

.tool-btn.active {
  background: #f39c12;
  transform: scale(1.1);
}

.tool-icon {
  font-size: 28rpx;
  margin-bottom: 2rpx;
}

.tool-name {
  font-size: 16rpx;
}

.menu-bar {
  display: flex;
  justify-content: space-around;
  padding: 12rpx;
  background: #2c3e50;
  border-top: 3rpx solid #34495e;
}

.menu-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6rpx;
  background: none;
  color: #ecf0f1;
  font-size: 18rpx;
  border: none;
  line-height: 1.2;
}

.menu-btn::after { border: none; }

.menu-icon {
  font-size: 32rpx;
  margin-bottom: 2rpx;
}

.shop-content {
  max-height: 60vh;
  overflow-y: auto;
}

.shop-category {
  font-size: 28rpx;
  color: #f39c12;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
}

.item-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.item-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx;
  background: #2c3e50;
  border-radius: 8rpx;
  border: 2rpx solid #7f8c8d;
}

.item-slot:active {
  background: #34495e;
}

.item-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.item-name {
  font-size: 20rpx;
  color: #ecf0f1;
  margin-bottom: 4rpx;
}

.item-price {
  font-size: 18rpx;
  color: #f39c12;
}