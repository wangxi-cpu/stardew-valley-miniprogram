/**
 * 星露谷物语 - 游戏页面样式（完整版）
 */

.game-container {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #000;
}

.game-canvas {
  width: 100%;
  height: 100%;
}

/* 种子选择器 */
.seed-selector {
  position: absolute;
  bottom: 70rpx;
  left: 0;
  width: 100%;
  background: rgba(52, 73, 94, 0.95);
  padding: 15rpx;
  transform: translateY(150%);
  transition: transform 0.3s ease;
  z-index: 100;
  border-top: 3rpx solid #f39c12;
}

.seed-selector.show {
  transform: translateY(0);
}

.seed-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.seed-title {
  font-size: 28rpx;
  color: #f39c12;
  font-weight: bold;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  background: #e74c3c;
  color: white;
  border: none;
  border-radius: 50%;
  font-size: 28rpx;
  padding: 0;
  line-height: 48rpx;
}

.close-btn::after { border: none; }

.seed-scroll {
  white-space: nowrap;
}

.seed-list {
  display: inline-flex;
  gap: 15rpx;
}

.seed-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 18rpx;
  background: rgba(44, 62, 80, 0.8);
  border-radius: 10rpx;
  border: 2rpx solid #7f8c8d;
  min-width: 100rpx;
}

.seed-item.selected {
  border-color: #f39c12;
  background: rgba(243, 156, 18, 0.2);
}

.seed-item:active {
  transform: scale(0.95);
}

.seed-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.seed-name {
  font-size: 20rpx;
  color: #ecf0f1;
  margin-bottom: 4rpx;
}

.seed-cost {
  font-size: 18rpx;
  color: #f39c12;
}

/* 通知 */
.notification {
  position: absolute;
  top: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(52, 152, 219, 0.9);
  color: white;
  padding: 12rpx 30rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  z-index: 200;
  animation: notifyAnim 0.3s ease;
}

@keyframes notifyAnim {
  from { opacity: 0; transform: translateX(-50%) translateY(-20rpx); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

/* 面板通用样式 */
.panel {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(52, 73, 94, 0.98);
  border-radius: 20rpx;
  padding: 25rpx;
  z-index: 300;
  min-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
  border: 3rpx solid #f39c12;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.5);
}

.panel.hidden { display: none; }

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.1);
}

.panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #f39c12;
}

.panel-close {
  width: 52rpx;
  height: 52rpx;
  background: #e74c3c;
  color: white;
  border: none;
  border-radius: 50%;
  font-size: 32rpx;
  padding: 0;
  line-height: 52rpx;
}

.panel-close::after { border: none; }

/* 商店 */
.shop-content {
  max-height: 60vh;
  overflow-y: auto;
}

.shop-category {
  font-size: 28rpx;
  color: #f39c12;
  font-weight: bold;
  margin-bottom: 15rpx;
  display: block;
}

.shop-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

.shop-item {
  display: flex;
  align-items: center;
  padding: 15rpx;
  background: rgba(44, 62, 80, 0.8);
  border-radius: 10rpx;
  border: 2rpx solid #7f8c8d;
}

.shop-item:active {
  background: rgba(52, 152, 219, 0.3);
}

.shop-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.shop-name {
  flex: 1;
  font-size: 24rpx;
  color: #ecf0f1;
}

.shop-price {
  font-size: 22rpx;
  color: #f39c12;
  font-weight: bold;
}

/* 背包 */
.backpack-content {
  max-height: 60vh;
  overflow-y: auto;
}

.backpack-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
}

.backpack-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: rgba(44, 62, 80, 0.8);
  border-radius: 8rpx;
  border: 2rpx solid #7f8c8d;
  position: relative;
}

.bp-icon {
  font-size: 32rpx;
}

.bp-count {
  position: absolute;
  bottom: 2rpx;
  right: 4rpx;
  font-size: 16rpx;
  color: #ecf0f1;
  background: rgba(0, 0, 0, 0.6);
  padding: 1rpx 6rpx;
  border-radius: 4rpx;
}

/* 响应式 */
@media (max-width: 750rpx) {
  .seed-item {
    min-width: 80rpx;
    padding: 10rpx;
  }
  
  .seed-icon {
    font-size: 28rpx;
  }
  
  .seed-name {
    font-size: 16rpx;
  }
  
  .panel {
    min-width: 500rpx;
    padding: 20rpx;
  }
  
  .shop-grid {
    grid-template-columns: 1fr;
  }
  
  .backpack-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}