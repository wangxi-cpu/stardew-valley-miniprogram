<!--
  星露谷物语 - 游戏页面
-->

<view class="game-container">
  <!-- 状态栏 -->
  <view class="status-bar">
    <view class="status-item">
      <text class="status-icon">💰</text>
      <text>{{playerGold}}g</text>
    </view>
    <view class="status-item">
      <text class="status-icon">❤️</text>
      <text>{{playerEnergy}}/{{playerMaxEnergy}}</text>
    </view>
    <view class="status-item">
      <text>{{gameSeason}} {{gameDay}}日</text>
    </view>
    <view class="status-item">
      <text>{{gameWeather}} {{gameTime}}</text>
    </view>
  </view>

  <!-- 游戏画布 -->
  <canvas 
    id="gameCanvas" 
    class="game-canvas"
    type="2d"
    bindtouchstart="handleCanvasTap"
  ></canvas>

  <!-- 种子选择器 -->
  <view class="seed-selector {{showSeedSelector ? 'show' : ''}}">
    <view class="seed-header">
      <text>选择种子</text>
      <button class="close-btn" bindtap="hideSeedSelector">×</button>
    </view>
    <scroll-view scroll-x class="seed-list">
      <view 
        wx:for="{{seeds}}" 
        wx:key="id"
        class="seed-item {{selectedSeed === item.id ? 'selected' : ''}}"
        data-seed="{{item.id}}"
        bindtap="selectSeed"
      >
        <text class="seed-icon">{{item.icon}}</text>
        <text class="seed-name">{{item.name}}</text>
        <text class="seed-cost">{{item.cost}}g</text>
      </view>
    </scroll-view>
  </view>

  <!-- 工具栏 -->
  <view class="toolbar">
    <view 
      wx:for="{{tools}}" 
      wx:key="id"
      class="tool-btn {{currentTool === item.id ? 'active' : ''}}"
      data-tool="{{item.id}}"
      bindtap="selectTool"
    >
      <text class="tool-icon">{{item.icon}}</text>
      <text class="tool-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 菜单栏 -->
  <view class="menu-bar">
    <button class="menu-btn" bindtap="showShopPanel">
      <text class="menu-icon">🏪</text>
      <text>商店</text>
    </button>
    <button class="menu-btn" bindtap="showBackpackPanel">
      <text class="menu-icon">🎒</text>
      <text>背包</text>
    </button>
    <button class="menu-btn" bindtap="goToMine">
      <text class="menu-icon">⛏️</text>
      <text>矿洞</text>
    </button>
    <button class="menu-btn" bindtap="goToFish">
      <text class="menu-icon">🎣</text>
      <text>钓鱼</text>
    </button>
    <button class="menu-btn" bindtap="saveGame">
      <text class="menu-icon">💾</text>
      <text>保存</text>
    </button>
  </view>

  <!-- 通知 -->
  <view class="notification" wx:if="{{showNotification}}">
    {{notification}}
  </view>

  <!-- 商店面板 -->
  <view class="panel {{showShop ? '' : 'hidden'}}">
    <view class="panel-header">
      <text class="panel-title">皮埃尔杂货店</text>
      <button class="panel-close" bindtap="hideShopPanel">×</button>
    </view>
    <view class="shop-content">
      <text class="shop-category">种子</text>
      <view class="item-grid">
        <view 
          wx:for="{{seeds}}" 
          wx:key="id"
          class="item-slot"
          bindtap="buySeed"
          data-seed="{{item.id}}"
          data-cost="{{item.cost}}"
        >
          <text class="item-icon">{{item.icon}}</text>
          <text class="item-name">{{item.name}}</text>
          <text class="item-price">{{item.cost}}g</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 背包面板 -->
  <view class="panel {{showBackpack ? '' : 'hidden'}}">
    <view class="panel-header">
      <text class="panel-title">背包</text>
      <button class="panel-close" bindtap="hideBackpackPanel">×</button>
    </view>
    <view class="item-grid">
      <view wx:for="{{36}}" wx:key="index" class="item-slot">
        <!-- 物品 -->
      </view>
    </view>
  </view>
</view>