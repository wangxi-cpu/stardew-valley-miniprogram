<!--
  星露谷物语 - 游戏页面（完整版）
-->

<view class="game-container">
  <!-- 游戏画布 -->
  <canvas 
    id="gameCanvas" 
    class="game-canvas"
    type="2d"
    bindtouchstart="handleTouchStart"
    bindtouchmove="handleTouchMove"
    bindtouchend="handleTouchEnd"
  ></canvas>

  <!-- 种子选择器 -->
  <view class="seed-selector {{showSeedSelector ? 'show' : ''}}">
    <view class="seed-header">
      <text class="seed-title">选择种子</text>
      <button class="close-btn" bindtap="hideSeedSelector">×</button>
    </view>
    <scroll-view scroll-x class="seed-scroll">
      <view class="seed-list">
        <view 
          class="seed-item {{selectedSeed === 'parsnip' ? 'selected' : ''}}"
          data-seed="parsnip"
          bindtap="selectSeed"
        >
          <text class="seed-icon">🥕</text>
          <text class="seed-name">防风草</text>
          <text class="seed-cost">20g</text>
        </view>
        <view 
          class="seed-item {{selectedSeed === 'potato' ? 'selected' : ''}}"
          data-seed="potato"
          bindtap="selectSeed"
        >
          <text class="seed-icon">🥔</text>
          <text class="seed-name">土豆</text>
          <text class="seed-cost">50g</text>
        </view>
        <view 
          class="seed-item {{selectedSeed === 'cauliflower' ? 'selected' : ''}}"
          data-seed="cauliflower"
          bindtap="selectSeed"
        >
          <text class="seed-icon">🥦</text>
          <text class="seed-name">花椰菜</text>
          <text class="seed-cost">80g</text>
        </view>
        <view 
          class="seed-item {{selectedSeed === 'tomato' ? 'selected' : ''}}"
          data-seed="tomato"
          bindtap="selectSeed"
        >
          <text class="seed-icon">🍅</text>
          <text class="seed-name">番茄</text>
          <text class="seed-cost">50g</text>
        </view>
        <view 
          class="seed-item {{selectedSeed === 'blueberry' ? 'selected' : ''}}"
          data-seed="blueberry"
          bindtap="selectSeed"
        >
          <text class="seed-icon">🫐</text>
          <text class="seed-name">蓝莓</text>
          <text class="seed-cost">80g</text>
        </view>
        <view 
          class="seed-item {{selectedSeed === 'corn' ? 'selected' : ''}}"
          data-seed="corn"
          bindtap="selectSeed"
        >
          <text class="seed-icon">🌽</text>
          <text class="seed-name">玉米</text>
          <text class="seed-cost">150g</text>
        </view>
        <view 
          class="seed-item {{selectedSeed === 'melon' ? 'selected' : ''}}"
          data-seed="melon"
          bindtap="selectSeed"
        >
          <text class="seed-icon">🍉</text>
          <text class="seed-name">西瓜</text>
          <text class="seed-cost">80g</text>
        </view>
        <view 
          class="seed-item {{selectedSeed === 'pumpkin' ? 'selected' : ''}}"
          data-seed="pumpkin"
          bindtap="selectSeed"
        >
          <text class="seed-icon">🎃</text>
          <text class="seed-name">南瓜</text>
          <text class="seed-cost">100g</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 通知 -->
  <view class="notification" wx:if="{{showNotification}}">
    {{notification}}
  </view>

  <!-- 商店面板 -->
  <view class="panel {{showShop ? '' : 'hidden'}}">
    <view class="panel-header">
      <text class="panel-title">皮埃尔杂货店</text>
      <button class="panel-close" bindtap="hideShopPanel">×</button>
    </view>
    <view class="shop-content">
      <text class="shop-category">🌱 种子</text>
      <view class="shop-grid">
        <view class="shop-item" bindtap="buySeed" data-seed="parsnip" data-cost="20">
          <text class="shop-icon">🥕</text>
          <text class="shop-name">防风草种子</text>
          <text class="shop-price">20g</text>
        </view>
        <view class="shop-item" bindtap="buySeed" data-seed="potato" data-cost="50">
          <text class="shop-icon">🥔</text>
          <text class="shop-name">土豆种子</text>
          <text class="shop-price">50g</text>
        </view>
        <view class="shop-item" bindtap="buySeed" data-seed="cauliflower" data-cost="80">
          <text class="shop-icon">🥦</text>
          <text class="shop-name">花椰菜种子</text>
          <text class="shop-price">80g</text>
        </view>
        <view class="shop-item" bindtap="buySeed" data-seed="tomato" data-cost="50">
          <text class="shop-icon">🍅</text>
          <text class="shop-name">番茄种子</text>
          <text class="shop-price">50g</text>
        </view>
        <view class="shop-item" bindtap="buySeed" data-seed="blueberry" data-cost="80">
          <text class="shop-icon">🫐</text>
          <text class="shop-name">蓝莓种子</text>
          <text class="shop-price">80g</text>
        </view>
        <view class="shop-item" bindtap="buySeed" data-seed="corn" data-cost="150">
          <text class="shop-icon">🌽</text>
          <text class="shop-name">玉米种子</text>
          <text class="shop-price">150g</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 背包面板 -->
  <view class="panel {{showBackpack ? '' : 'hidden'}}">
    <view class="panel-header">
      <text class="panel-title">背包</text>
      <button class="panel-close" bindtap="hideBackpackPanel">×</button>
    </view>
    <view class="backpack-content">
      <view class="backpack-grid">
        <view class="backpack-item">
          <text class="bp-icon">🥕</text>
          <text class="bp-count">15</text>
        </view>
        <view class="backpack-item">
          <text class="bp-icon">🌱</text>
          <text class="bp-count">10</text>
        </view>
        <view class="backpack-item">
          <text class="bp-icon">💧</text>
          <text class="bp-count">1</text>
        </view>
      </view>
    </view>
  </view>
</view>